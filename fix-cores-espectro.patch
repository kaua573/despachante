+// Mesma fórmula de luminância (WCAG 2.0) usada no backend, para a prévia
+// reagir instantaneamente sem precisar ir ao servidor.
+function luminanciaRelativa(hex) {
+  const h = hex.replace('#', '');
+  const canais = [0, 2, 4].map(i => {
+    let c = parseInt(h.substring(i, i + 2), 16) / 255;
+    return c <= 0.03928 ? c / 12.92 : Math.pow((c + 0.055) / 1.055, 2.4);
+  });
+  return 0.2126 * canais[0] + 0.7152 * canais[1] + 0.0722 * canais[2];
+}
+
+function corContraste(hex) {
+  return luminanciaRelativa(hex) > 0.5 ? '#1c2333' : '#ffffff';
+}
+
+function hexValido(hex) {
+  return /^#[0-9a-fA-F]{6}$/.test(hex);
+}
+
+function atualizarPreview(tipo, hex) {
+  const preview = document.getElementById(`cor-${tipo}-preview`);
+  preview.style.background = hex;
+  preview.style.color = corContraste(hex);
+  preview.textContent = 'Aa — assim ficará o texto sobre essa cor';
+  preview.style.fontSize = '12px';
+  preview.style.padding = '0 12px';
+}
+
+function definirCor(tipo, hex) {
+  if (!hexValido(hex)) return;
+  hex = hex.toLowerCase();
+  if (tipo === 'tema') temaCorCurrent = hex; else pdfCorCurrent = hex;
+  document.getElementById(`cor-${tipo}-picker`).value = hex;
+  document.getElementById(`cor-${tipo}-hex`).value = hex;
+  atualizarPreview(tipo, hex);
+  document.querySelectorAll(`#swatch-${tipo} .swatch`).forEach(s => s.classList.toggle('selecionada', s.dataset.hex === hex));
+}
+
+function onCorChange(tipo, hex) { definirCor(tipo, hex); }
+
+function onHexDigitado(tipo, valor) {
+  valor = valor.trim();
+  if (!valor.startsWith('#')) valor = '#' + valor;
+  if (hexValido(valor)) definirCor(tipo, valor);
