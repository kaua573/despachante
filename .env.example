# Chave secreta do Flask. Troque por uma string longa e aleatória em produção.
# Geração sugerida: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-esta-chave-em-producao

# URL de conexão com o banco de dados.
# Omita para usar SQLite local (despachante.db) — adequado para desenvolvimento.
# PostgreSQL (produção): postgresql://usuario:senha@host:5432/nome_banco
# DATABASE_URL=

# Ambiente de execução. Valores aceitos: development | production
# Em production, DATABASE_URL passa a ser obrigatória.
FLASK_ENV=development
