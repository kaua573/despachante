+  // ── Clientes (consulta rápida — cadastro/edição continuam em /clientes) ──────
+  async function carregarClientesDash() {
+    const busca = document.getElementById('busca-clientes-dash').value;
+    const dados = await apiFetch('/api/clientes?busca=' + encodeURIComponent(busca));
+    if (!dados) return;
+    const tbody = document.getElementById('tbody-clientes-dash');
+    tbody.innerHTML = dados.length ? dados.map(c => `<tr>
+      <td><strong>${c.nome}</strong></td>
+      <td>${c.cpf || '—'}</td>
+      <td>${c.telefone || '—'}</td>
+      <td>${c.email || '—'}</td>
+      <td style="max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${c.observacao || ''}">${c.observacao || '—'}</td>
+      <td><a class="btn btn-primary btn-sm btn-icon" title="Veículos" href="/clientes/${c.id}/veiculos">{{ icon('car','icon icon-sm') }}</a></td>
+    </tr>`).join('') : `<tr><td colspan="6"><div class="empty-state"><p>Nenhum cliente encontrado</p></div></td></tr>`;
+  }
+
   carregar();
+  carregarClientesDash();
